{
  "uid": "harbor-registry-cve",
  "title": "Harbor — Registre & CVE",
  "tags": ["harbor", "devsecops", "cve"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "État du registre Harbor",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Harbor disponible",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(harbor_up)" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Projets",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 5, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(harbor_statistics_total_project_amount)" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Dépôts",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 9, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(harbor_statistics_total_repo_amount)" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Artefacts scannés",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 13, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(harbor_artifacts_scanned_total)" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "purple", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Stockage consommé",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [{ "refId": "A", "expr": "max(harbor_statistics_total_storage_consumption)" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "row",
      "title": "Vulnérabilités (CVE) — scanner Trivy intégré à Harbor",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "stat",
      "title": "Critiques",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 6 },
      "targets": [{ "refId": "A", "expr": "sum(harbor_image_vulnerabilities{severity=\"Critical\"})" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "noValue": "0" } },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Élevées (High)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 6 },
      "targets": [{ "refId": "A", "expr": "sum(harbor_image_vulnerabilities{severity=\"High\"})" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] }, "noValue": "0" } },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Moyennes (Medium)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 6 },
      "targets": [{ "refId": "A", "expr": "sum(harbor_image_vulnerabilities{severity=\"Medium\"})" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }, "noValue": "0" } },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Faibles (Low)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 15, "y": 6 },
      "targets": [{ "refId": "A", "expr": "sum(harbor_image_vulnerabilities{severity=\"Low\"})" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }, "noValue": "0" } },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "title": "Corrigeables (fixable)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 6 },
      "targets": [{ "refId": "A", "expr": "sum(harbor_image_fixable_vulnerabilities)" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] }, "noValue": "0" } },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "barchart",
      "title": "Vulnérabilités par sévérité",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "sum by (severity) (harbor_image_vulnerabilities)", "legendFormat": "{{severity}}", "instant": true }
      ],
      "fieldConfig": { "defaults": { "noValue": "0" } },
      "options": { "orientation": "horizontal", "showValue": "always" }
    },
    {
      "type": "table",
      "title": "CVE par dépôt et sévérité",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "refId": "A", "expr": "harbor_image_vulnerabilities{severity=~\"Critical|High|Medium|Low\"} > 0", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "namespace": true, "service": true, "endpoint": true, "container": true, "pod": true, "project": false }, "renameByName": { "repository": "Dépôt", "tag": "Tag", "severity": "Sévérité", "Value": "Nombre", "project": "Projet" } } }
      ]
    },
    {
      "type": "row",
      "title": "Trafic & performance du registre",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "Requêtes API Harbor par code HTTP (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [
        { "refId": "A", "expr": "sum by (code) (rate(harbor_core_http_request_total[$__rate_interval]))", "legendFormat": "{{code}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    },
    {
      "type": "timeseries",
      "title": "Latence moyenne de l'API Harbor",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(harbor_core_http_request_duration_seconds_sum[$__rate_interval])) / sum(rate(harbor_core_http_request_duration_seconds_count[$__rate_interval]))", "legendFormat": "latence moyenne" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 15 } } }
    }
  ]
}
